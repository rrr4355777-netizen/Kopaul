        analyzeBtnLoading: 'ခွဲခြမ်းဆွဲနေပါမည်...',
        generateTitle: '🎨 ပြင်ဆိုင်စနစ်ဖန်တီးပါမည်',
        roomLabel: 'အခန်းအမျိုးအစား',
        roomLiving: 'ဧည့်ခန်း', roomBedroom: 'အိပ်ခန်း', roomBathroom: 'ရေချိုးခန်း',
        roomKitchen: 'မီးဖုတ်ခန်း', roomDining: 'ထမင်းစားခန်း', roomBalcony: 'လက်တင်',
        generateBtn: '✨ ပြင်ဆိုင်စနစ်ဖန်တီးပါမည်',
        generating: 'AI သည် ပြင်ဆိုင်စနစ်ကို ဖန်တီးနေပါမည်...',
        searchTitle: '🔎 ဆင်တူပြင်ဆိုင်စနစ်ရှာဖွေပါမည်',
        searchDesc: 'ကြေးမုံအစိတ်အပိုင်းအရ အမှန်တကယ်ပုံများကို Unsplash မှာရှာဖွေပါမည်',
        searchBtn: '🔍 ဆင်တူပါမည်',
        searchLoading: 'ပုံများရှာဖွေနေပါမည်...',
        demoWarning: '⚠️ ဒီမိုမုံပါ - အမှန်တကယ်ပုံများအတွက် UNSPLASH_ACCESS_KEY သတ်မှတ်ပါမည်',
        success: '✅ ပြင်ဆိုင်စနစ် ဖန်တီးပါပါမည်!',
        pattern: 'ပုံစံ', style: 'စတိုင်', mood: 'သဘောသား', recommend: 'အကြံပါမည်',
        uploadSuccess: 'တင်ပါပါမည်!', uploading: 'တင်နေပါမည်...',
        clickOrDrag: 'ဤနေရာသို့ ပုံကလစ်ဖ်သို့ ဆွဲယူပါမည်',
        widthPlaceholder: 'အနံ', heightPlaceholder: 'အမြင့်',
        keywordSearch: 'ရှာဖွေသည့်စာလုံး:',
        detectedColor: 'သတ်မှတ်သည့်အရောင်'
      }
    };
    // 當前語言
    let currentLang = 'zh-TW';

    function changeLanguage(lang) {
      currentLang = lang;
      const t = translations[lang];
      
      // 更新標題和副標題
      document.querySelector('h1').textContent = t.title;
      document.querySelector('.subtitle').textContent = t.subtitle;
      
      // 更新所有 card 標題
      document.querySelectorAll('.card h2')[0].textContent = t.uploadTitle;
      document.querySelectorAll('.card h2')[1].textContent = t.specTitle;
      document.querySelectorAll('.card h2')[2].textContent = t.generateTitle;
      document.querySelectorAll('.card h2')[3].textContent = t.searchTitle;
      
      // 更新標籤
      document.querySelectorAll('label')[0].textContent = t.sizeLabel;
      document.querySelectorAll('label')[1].textContent = t.colorLabel;
      document.querySelectorAll('label')[2].textContent = t.materialLabel;
      document.querySelectorAll('label')[3].textContent = t.roomLabel;
      
      // 更新按鈕文字
      document.getElementById('analyzeBtn').textContent = t.analyzeBtn;
      document.getElementById('generateBtn').textContent = t.generateBtn;
      document.getElementById('searchBtn').textContent = t.searchBtn;
      
      // 更新上傳區域
      const uploadP = document.querySelector('#uploadArea p');
      uploadP.textContent = t.uploadText;
      document.querySelector('#uploadArea p:last-of-type').textContent = t.uploadHint;
      
      // 更新 loading 文字
      document.querySelector('#loading p').textContent = t.generating;
      document.querySelector('#searchLoading p').textContent = t.searchLoading;
      
      // 更新搜尋說明
      document.querySelectorAll('.card p')[3].textContent = t.searchDesc;
      
      // 更新 Select 選項
      const colorSelect = document.getElementById('color');
      colorSelect.options[0].text = t.selectColor;
      colorSelect.options[1].text = t.colorLightGray;
      colorSelect.options[2].text = t.colorDarkGray;
      colorSelect.options[3].text = t.colorBeige;
      colorSelect.options[4].text = t.colorLightBrown;
      colorSelect.options[5].text = t.colorDarkBrown;
      colorSelect.options[6].text = t.colorWhite;
      colorSelect.options[7].text = t.colorBlack;
      colorSelect.options[8].text = t.colorBlue;
      colorSelect.options[9].text = t.colorGreen;
      
      const materialSelect = document.getElementById('material');
      materialSelect.options[0].text = t.selectMaterial;
      materialSelect.options[1].text = t.materialTile;
      materialSelect.options[2].text = t.materialStone;
      materialSelect.options[3].text = t.materialWood;
      materialSelect.options[4].text = t.materialMosaic;
      materialSelect.options[5].text = t.materialConcrete;
      
      const roomSelect = document.getElementById('roomType');
      roomSelect.options[0].text = t.roomLiving;
      roomSelect.options[1].text = t.roomBedroom;
      roomSelect.options[2].text = t.roomBathroom;
      roomSelect.options[3].text = t.roomKitchen;
      roomSelect.options[4].text = t.roomDining;
      roomSelect.options[5].text = t.roomBalcony;
      
      // 更新尺寸單位
      const sizeUnitSelect = document.getElementById('sizeUnit');
      if (sizeUnitSelect) {
        sizeUnitSelect.options[0].text = t.unitCm || 'cm';
        sizeUnitSelect.options[1].text = t.unitSqft || 'sq ft';
        sizeUnitSelect.options[2].text = t.unitSqm || 'sq m';
      }
      
      // 更新 input placeholder
      document.getElementById('width').placeholder = t.widthPlaceholder;
      document.getElementById('height').placeholder = t.heightPlaceholder;
      
      // 儲存語言到 localStorage
      localStorage.setItem('tileAppLang', lang);
    }

    // 載入時恢復語言設定
    window.addEventListener('load', () => {
      const savedLang = localStorage.getItem('tileAppLang');
      if (savedLang) {
        document.getElementById('langSelect').value = savedLang;
        changeLanguage(savedLang);
      }
    });

    // ========== 以下是原本的程式碼 ==========
    let currentFilePath = '';
    
    // 上傳處理
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    const previewImg = document.getElementById('previewImg');
    const t = () => translations[currentLang];
    
    uploadArea.addEventListener('click', () => fileInput.click());
    uploadArea.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadArea.classList.add('dragover');
    });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
    uploadArea.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadArea.classList.remove('dragover');
      if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
    });
    fileInput.addEventListener('change', (e) => {
      if (e.target.files[0]) handleFile(e.target.files[0]);
    });
    
    async function handleFile(file) {
      const formData = new FormData();
      formData.append('tileImage', file);
      
      uploadArea.querySelector('p').textContent = t().uploading;
      
      try {
        const res = await fetch('/api/upload', { method: 'POST', body: formData });
        const data = await res.json();
        
        if (data.success) {
          currentFilePath = data.filePath;
          previewImg.src = data.filePath;
          previewImg.style.display = 'block';
          uploadArea.querySelector('p').textContent = t().uploadSuccess;
        } else {
          alert(data.error || '上傳失敗');
        }
      } catch (err) {
        alert('上傳錯誤: ' + err.message);
      }
    }
    
    let savedFeatures = null;
    let savedTileInfo = null;
    
    // 分析特徵
    document.getElementById('analyzeBtn').addEventListener('click', async () => {
      if (!currentFilePath) {
        alert('請先上傳磁磚圖片');
        return;
      }
      
      const width = document.getElementById('width').value;
      const height = document.getElementById('height').value;
      const sizeUnit = document.getElementById('sizeUnit').value;
      const color = document.getElementById('color').value;
      const material = document.getElementById('material').value;
      
      const btn = document.getElementById('analyzeBtn');
      btn.disabled = true;
      btn.textContent = t().analyzeBtnLoading;
      
      try {
        const res = await fetch('/api/analyze', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tilePath: currentFilePath,
            width, height, sizeUnit, color, material
          })
        });
        const data = await res.json();
        
        if (data.success) {
          const f = data.features;
          // 儲存完整的 features，包括偵測到的顏色
          savedFeatures = { 
            pattern: f.pattern, 
            style: f.style, 
            mood: f.mood,
            detectedColor: f.detectedColor || document.getElementById('color').value
          };
          
          // 如果有偵測到的顏色，自動選取
          if (f.detectedColor) {
            const colorSelect = document.getElementById('color');
            // 嘗試找到匹配的選項
            const options = colorSelect.options;
            let found = false;
            for (let i = 0; i < options.length; i++) {
              if (options[i].value === f.detectedColor) {
                colorSelect.selectedIndex = i;
                found = true;
                break;
              }
            }
            // 如果沒有匹配，顯示偵測到的顏色
            if (!found && f.detectedColor !== document.getElementById('color').value) {
              console.log('偵測到顏色:', f.detectedColor);
            }
          }
          
          savedTileInfo = {
            color: document.getElementById('color').value,
            material: document.getElementById('material').value,
            roomType: document.getElementById('roomType').value
          };
          
          // 顯示偵測到的顏色（如果有的話）
          const detectedColorHtml = f.detectedColor ? 
            `<div class="feature-item"><span class="feature-label">${t().detectedColor}:</span>${f.detectedColor} <span style="font-size:12px;color:#888;">(AI)</span></div>` : '';
          
          document.getElementById('analyzeResult').innerHTML = `
            <div class="features-result">
              ${detectedColorHtml}
              <div class="feature-item"><span class="feature-label">${t().pattern}:</span>${f.pattern}</div>
              <div class="feature-item"><span class="feature-label">${t().style}:</span>${f.style}</div>
              <div class="feature-item"><span class="feature-label">${t().mood}:</span>${f.mood}</div>
              <div class="feature-item"><span class="feature-label">${t().recommend}:</span>${f.recommendedRooms.join(', ')}</div>
            </div>
          `;
          document.getElementById('generateBtn').disabled = false;
          document.getElementById('searchBtn').disabled = false;
        }
      } catch (err) {
        alert('分析失敗: ' + err.message);
      } finally {
        btn.disabled = false;
        btn.textContent = t().analyzeBtn;
      }
    });
    
    // 生成場景
    document.getElementById('generateBtn').addEventListener('click', async () => {
      if (!currentFilePath || !savedFeatures) {
        alert('請先上傳磁磚並分析');
        return;
      }
      
      const roomType = document.getElementById('roomType').value;
      const features = savedFeatures;
      
      document.getElementById('loading').style.display = 'block';
      document.getElementById('generateBtn').disabled = true;
      
      try {
        const res = await fetch('/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tilePath: currentFilePath, features, roomType })
        });
        const data = await res.json();
        
        if (data.success) {
          document.getElementById('generateResult').innerHTML = `
            <div class="result-area">
              <img class="scene-img" src="${data.imageUrl}" alt="Scene">
              <p class="success">${t().success}</p>
              <p style="font-size:13px;color:#666;">Prompt: ${data.prompt}</p>
            </div>
          `;
        }
      } catch (err) {
        document.getElementById('generateResult').innerHTML = 
          `<p class="error">生成失敗: ${err.message}</p>`;
      } finally {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('generateBtn').disabled = false;
      }
    });
    
    // 搜尋相似場景
    document.getElementById('searchBtn').addEventListener('click', async () => {
      if (!savedTileInfo) {
        alert('請先分析磁磚特徵');
        return;
      }
      
      const { color, material, roomType } = savedTileInfo;
      
      document.getElementById('searchLoading').style.display = 'block';
      document.getElementById('searchBtn').disabled = true;
      
      try {
        const res = await fetch('/api/search-scenes', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ color, material, roomType })
        });
        const data = await res.json();
        
        if (data.success) {
          const images = data.images;
          const modeLabel = data.mode === 'demo' ? `<p style="color:#888;font-size:13px;">${t().demoWarning}</p>` : '';
          
          const galleryHtml = images.map(img => `
            <div>
              <img src="${img.thumbUrl}" alt="${img.description || 'Scene'}" 
                   onclick="window.open('${img.regularUrl}', '_blank')"
                   title="${img.description || 'Click for larger image'}">
              <p class="photo-credit">📷 ${img.photographer}</p>
            </div>
          `).join('');
          
          document.getElementById('searchResult').innerHTML = `
            ${modeLabel}
            <div class="scene-gallery">${galleryHtml}</div>
            <p style="font-size:13px;color:#666;margin-top:12px;">${t().keywordSearch} ${data.query}</p>
          `;
        }
      } catch (err) {
        document.getElementById('searchResult').innerHTML = 
          `<p class="error">搜尋失敗: ${err.message}</p>`;
      } finally {
        document.getElementById('searchLoading').style.display = 'none';
        document.getElementById('searchBtn').disabled = false;
      }
    });
  </script>
</body>
</html>