# ========== Replicate API（主要方案）==========
# 在 https://replicate.com/account 取得 API Token
REPLICATE_API_TOKEN=your_replicate_token_here

# ========== HuggingFace API（備用方案，需要 Pro）==========
# 在 https://huggingface.co/settings/tokens 取得
# HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# ========== 伺服器設定 ==========
PORT=3000
HOST=0.0.0.0